{
  "unit": "Grade 4",
  "grammar_points": [
    {
      "grammar_id": "grammar_g4_001_can",
      "unit": "Grade 4",
      "grammar_point": "情态动词 can 的用法",
      "category": "structure",
      "student_explanation": "can 表示'能、会'，后面直接跟动词原形，不用加 s 或 ing",
      "teacher_explanation": "can 是情态动词，后接动词原形，否定形式为 can't/cannot，疑问句将 can 提前",
      "correct_examples": [
        {
          "sentence": "I can swim.",
          "translation": "我会游泳。",
          "highlight": "can swim"
        },
        {
          "sentence": "She can't fly.",
          "translation": "她不会飞。",
          "highlight": "can't fly"
        },
        {
          "sentence": "Can you ride a bike?",
          "translation": "你会骑自行车吗？",
          "highlight": "Can you"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "I can swims.",
          "correction": "I can swim.",
          "error_type": "动词形式错"
        },
        {
          "sentence": "She cans swim.",
          "correction": "She can swim.",
          "error_type": "动词形式错"
        }
      ],
      "error_reason": "学生容易在 can 后面的动词上加 s/es，或者给 can 本身加 s",
      "error_tags": [
        "动词形式错",
        "情态动词用错"
      ],
      "practice_types": [
        "选择",
        "填空",
        "改错"
      ],
      "difficulty": 2,
      "related_vocabulary": [
        "can",
        "can't"
      ]
    },
    {
      "grammar_id": "grammar_g4_002_seasons_weather",
      "unit": "Grade 4",
      "grammar_point": "描述天气的句型",
      "category": "pattern",
      "student_explanation": "用 It's + 天气形容词 来描述天气，如 It's sunny / rainy / windy",
      "teacher_explanation": "描述天气用 It's + adj. 结构，it 在这里是形式主语，指代天气",
      "correct_examples": [
        {
          "sentence": "It's sunny today.",
          "translation": "今天天气晴朗。",
          "highlight": "It's sunny"
        },
        {
          "sentence": "It's cold in winter.",
          "translation": "冬天很冷。",
          "highlight": "It's cold"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "It's sunny and rain today.",
          "correction": "It's sunny today.",
          "error_type": "句型用错"
        },
        {
          "sentence": "The weather is sunny today.",
          "correction": "It's sunny today.",
          "error_type": "表达冗余"
        }
      ],
      "error_reason": "学生容易用 Today is... 代替 It's... 来描述天气",
      "error_tags": [
        "句型用错",
        "表达冗余"
      ],
      "practice_types": [
        "选择",
        "填空",
        "造句"
      ],
      "difficulty": 2,
      "related_vocabulary": [
        "sunny",
        "rainy",
        "cloudy",
        "windy",
        "snowy"
      ]
    },
    {
      "grammar_id": "grammar_g4_003_what_time",
      "unit": "Grade 4",
      "grammar_point": "询问时间 What time is it?",
      "category": "pattern",
      "student_explanation": "用 What time is it? 问时间，回答用 It's + 时间",
      "teacher_explanation": "What time is it? 是询问当前时间的固定句型，也可以用 What's the time?",
      "correct_examples": [
        {
          "sentence": "What time is it? It's seven o'clock.",
          "translation": "现在几点了？现在七点。",
          "highlight": "What time"
        },
        {
          "sentence": "It's seven thirty.",
          "translation": "现在七点半。",
          "highlight": "seven thirty"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "What time is?",
          "correction": "What time is it?",
          "error_type": "缺少主语"
        },
        {
          "sentence": "It's seven hours.",
          "correction": "It's seven o'clock.",
          "error_type": "表达错误"
        }
      ],
      "error_reason": "学生容易遗漏 it 或使用错误的时间表达方式",
      "error_tags": [
        "缺少主语",
        "表达错误"
      ],
      "practice_types": [
        "选择",
        "问答",
        "填空"
      ],
      "difficulty": 2,
      "related_vocabulary": [
        "time",
        "o'clock",
        "thirty",
        "fifteen"
      ]
    },
    {
      "grammar_id": "grammar_g4_004_there_be",
      "unit": "Grade 4",
      "grammar_point": "There be 句型",
      "category": "structure",
      "student_explanation": "用 There is/are + 某物 + 某地 表示'某处有某物'，近处用 is，远处复数用 are",
      "teacher_explanation": "There be 句型表示存在，be 动词由后面最近的名词决定（就近原则）",
      "correct_examples": [
        {
          "sentence": "There is a book on the desk.",
          "translation": "桌子上有一本书。",
          "highlight": "There is"
        },
        {
          "sentence": "There are some birds in the tree.",
          "translation": "树上有一些鸟。",
          "highlight": "There are"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "There is some birds in the tree.",
          "correction": "There are some birds in the tree.",
          "error_type": "be动词用错"
        },
        {
          "sentence": "Have a book on the desk.",
          "correction": "There is a book on the desk.",
          "error_type": "句型用错"
        }
      ],
      "error_reason": "学生容易把 There is 和 There are 混淆，也容易和 have/has 混淆",
      "error_tags": [
        "be动词用错",
        "句型用错"
      ],
      "practice_types": [
        "选择",
        "填空",
        "改错"
      ],
      "difficulty": 2,
      "related_vocabulary": [
        "there is",
        "there are"
      ]
    },
    {
      "grammar_id": "grammar_g4_005_likes_doing",
      "unit": "Grade 4",
      "grammar_point": "like + 动名词/名词",
      "category": "structure",
      "student_explanation": "like 后面可以跟名词或动名词（-ing 形式），表示'喜欢...'",
      "teacher_explanation": "like + doing sth 表示喜欢做某事，like + 名词表示喜欢某物",
      "correct_examples": [
        {
          "sentence": "I like reading.",
          "translation": "我喜欢阅读。",
          "highlight": "like reading"
        },
        {
          "sentence": "She likes cats.",
          "translation": "她喜欢猫。",
          "highlight": "likes cats"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "I like read.",
          "correction": "I like reading.",
          "error_type": "动词形式错"
        },
        {
          "sentence": "She like cats.",
          "correction": "She likes cats.",
          "error_type": "动词形式错"
        }
      ],
      "error_reason": "学生容易在 like 后面用动词原形而不是动名词，也容易忽略第三人称单数",
      "error_tags": [
        "动词形式错"
      ],
      "practice_types": [
        "选择",
        "填空",
        "造句"
      ],
      "difficulty": 2,
      "related_vocabulary": [
        "like",
        "likes"
      ]
    },
    {
      "grammar_id": "grammar_g4_006_present_continuous",
      "unit": "Grade 4",
      "grammar_point": "现在进行时 be + doing",
      "category": "structure",
      "student_explanation": "用 am/is/are + 动词ing 表示正在做的事",
      "teacher_explanation": "现在进行时 = be + V-ing，表示正在进行的动作。否定在 be 后加 not",
      "correct_examples": [
        {
          "sentence": "I am reading a book.",
          "translation": "我正在看书。",
          "highlight": "am reading"
        },
        {
          "sentence": "She is singing.",
          "translation": "她正在唱歌。",
          "highlight": "is singing"
        },
        {
          "sentence": "They are playing football.",
          "translation": "他们正在踢足球。",
          "highlight": "are playing"
        }
      ],
      "wrong_examples": [
        {
          "sentence": "I am read a book.",
          "correction": "I am reading a book.",
          "error_type": "动词形式错"
        },
        {
          "sentence": "She is sing.",
          "correction": "She is singing.",
          "error_type": "动词形式错"
        }
      ],
      "error_reason": "学生容易忘记在动词后面加 -ing，或者 be 动词和主语不匹配",
      "error_tags": [
        "动词形式错",
        "be动词用错"
      ],
      "practice_types": [
        "选择",
        "填空",
        "看图说话"
      ],
      "difficulty": 3,
      "related_vocabulary": [
        "am",
        "is",
        "are",
        "-ing"
      ]
    }
  ]
}